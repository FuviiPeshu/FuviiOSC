<UserControl x:Class="FuviiOSC.Common.FuviiHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    IsHitTestVisible="False">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF6932DD" Offset="0"/>
            <GradientStop Color="#526932DD" Offset="0.32"/>
            <GradientStop Color="#006932DD" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BorderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF6932DD" Offset="0"/>
            <GradientStop Color="#006932DD" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>
    <Grid>
        <Border x:Name="BodyBackground" CornerRadius="5"
            Background="#086932DD"
            BorderBrush="{StaticResource BorderGradient}"
            BorderThickness="2"/>
        <Path x:Name="BackgroundPath" Fill="{StaticResource HeaderGradient}"/>
        <Canvas ClipToBounds="False">
            <Image x:Name="WatermarkImage"
                Source="pack://application:,,,/FuviiOSC;component/_Common/FuviiLogo.png"
                Opacity="0.0032"
                Stretch="Uniform"
                RenderOptions.BitmapScalingMode="HighQuality"/>
        </Canvas>
        <Image x:Name="LogoImage"
            Source="pack://application:,,,/FuviiOSC;component/_Common/FuviiLogo.png"
            Width="50" Height="50"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,-8,-8,0"
            RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</UserControl>
